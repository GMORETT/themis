# Themis — environment template
# Copy to `.env` and fill in. `.env` is gitignored.

# --- Database ---
DATABASE_URL=postgresql://themis:themis@localhost:5432/themis

# --- Cache ---
REDIS_URL=redis://localhost:6379/0

# --- Vector store ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- LLM providers (Phase 2+) ---
# In dev we default to Ollama; in prod we use AWS Bedrock.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_FAST=anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_MODEL_SMART=anthropic.claude-sonnet-4-20250514-v1:0

# --- Embeddings ---
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# --- Observability (Phase 7) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# --- App ---
ENV=dev
LOG_LEVEL=INFO
